# App runtime
APP_ENV=production
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=2
LOG_LEVEL=info

# Security (public deployment)
ENABLE_BASIC_AUTH=1
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=CHANGE_ME_APP_PASSWORD
ALLOWED_HOSTS=DEINE_DOMAIN
TRUSTED_ORIGINS=https://DEINE_DOMAIN
CSRF_PROTECT=1
STRICT_CSRF_CHECK=0
FORCE_HTTPS_REDIRECT=0
COOKIE_SECURE=1
COOKIE_HTTPONLY=1
MAX_UPLOAD_MB=25

# Default admin bootstrap / recovery
DEFAULT_ADMIN_EMAIL=admin@filament.local
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_API_TOKEN=

# Database
# Docker Compose (PostgreSQL only):
POSTGRES_DB=filament_db
POSTGRES_USER=filament
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg://filament:CHANGE_ME_STRONG_PASSWORD@db:5432/filament_db

# Optional live slot-state poller
SLOT_STATE_POLL_INTERVAL_SEC=45
SLOT_STATE_PROVIDER=feed
SLOT_STATE_FEED_URL=
SLOT_STATE_FEED_TOKEN=
SLOT_STATE_FEED_FILE=
SLOT_STATE_SOURCE=slot-poller
SLOT_STATE_PROJECT=private
SLOT_STATE_STALE_MINUTES=10

# Direct Bambu MQTT polling (optional)
# Example:
# BAMBU_PRINTERS_JSON=[{"name":"P1S-01","host":"192.168.1.50","serial":"01S00XXXXXXXX","access_code":"12345678"}]
BAMBU_PRINTERS_JSON=[]
SLOT_STATE_BAMBU_TIMEOUT_SEC=10
