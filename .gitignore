# FilamentDB: local env and secrets
.env
.env.*
!.env.example

# FilamentDB: local backups generated by scripts/UI
artifacts/db-backups/*
!artifacts/db-backups/.gitkeep
*.dump
*.dump.sha256

# FilamentDB: local debug helpers
scripts/_tmp_*.py

# Python bytecode and cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage output
.coverage
.coverage.*
htmlcov/

# Runtime logs and temp files
*.log
*.tmp
*.temp
.tmp_visual_regression/

# Build/distribution artifacts
build/
dist/
*.egg-info/

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
