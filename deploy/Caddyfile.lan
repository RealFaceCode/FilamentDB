{
    default_sni {$LAN_HOST}

    servers {
        protocols h1 h2
    }
}

http://{$LAN_HOST}:80 {
    redir https://{$LAN_HOST}:8443{uri} 308
}

https://{$LAN_HOST}:443 {
    tls internal {
        key_type rsa2048
    }
    encode zstd gzip

    reverse_proxy web:8000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
    }
}
