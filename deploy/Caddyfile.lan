{
    default_sni {$LOCAL_IP:localhost}

    servers {
        protocols h1 h2
    }
}

http://{$LOCAL_IP:localhost}:80 {
    redir https://{$LOCAL_IP:localhost}:8443{uri} 308
}

https://{$LOCAL_IP:localhost}:443 {
    tls internal {
        key_type rsa2048
    }
    encode zstd gzip

    reverse_proxy web:8000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
    }
}
